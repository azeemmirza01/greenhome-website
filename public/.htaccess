# Hostinger (Apache): serve Next.js static export at clean URLs (/quote, /services/foo)
Options -MultiViews
RewriteEngine On
RewriteBase /

# Leave real files and folders as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# /quote/ or /services/foo/ -> quote.html or services/foo.html
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteCond %{DOCUMENT_ROOT}%1.html -f
RewriteRule ^(.+)/$ $1.html [L]

# /quote or /services/foo -> quote.html or services/foo.html
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

ErrorDocument 404 /404.html
